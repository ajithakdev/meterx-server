{
  "name": "meterx",
  "version": "2026.0.319-MR1.0",
  "private": true,
  "description": "MeterX - Open source internet speed test browser extension",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "npm run build --workspaces --if-present",
    "start": "node packages/server/dist/server.js",
    "dev": "npm run build --workspaces --if-present && node packages/server/dist/server.js",
    "test": "npm run test --workspaces --if-present"
  },
  "keywords": ["speed-test", "browser-extension", "network-monitor"],
  "author": "ajithakdev (https://github.com/ajithakdev)",
  "license": "MIT",
  "devDependencies": {
    "@eslint/css": "^0.7.0",
    "@eslint/js": "^9.26.0",
    "@eslint/markdown": "^6.4.0",
    "eslint": "^9.26.0",
    "globals": "^16.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.32.0",
    "esbuild": "^0.25.0",
    "vitest": "^3.0.0"
  }
}
